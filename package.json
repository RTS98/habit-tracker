{
  "name": "habit-tracker",
  "version": "1.0.0",
  "description": "Habit tracker API built with Node.js, Express, and PostgreSQL",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --outDir dist",
    "dev": "NODE_ENV=development tsx --watch src/index.ts",
    "start": "NODE_ENV=production node dist/src/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "habit",
